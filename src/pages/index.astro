---

---

<html lang='es'>
	<head>
		<meta charset='utf-8' />
		<link
			rel='icon'
			type='image/svg+xml'
			href='/favicon.svg'
		/>
		<meta
			name='viewport'
			content='width=device-width, initial-scale=1'
		/>
		<meta
			name='theme-color'
			content='#0a0a0a'
		/>
		<title>Mar An Cloth — Nostalgia Programada</title>

		<link
			rel='preconnect'
			href='https://fonts.googleapis.com'
		/>
		<link
			rel='preconnect'
			href='https://fonts.gstatic.com'
			crossorigin
		/>
		<link
			href='https://fonts.googleapis.com/css2?family=Righteous&family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Mono:wght@400;500&display=swap'
			rel='stylesheet'
		/>

		<style>
			/* ─── Tokens ─────────────────────────────────────────────────────────── */
			:root {
				--color-void: #0a0a0a;
				--color-lunar: #f5f5f0;
				--color-chrome: #c8c8c8;
				--color-orbit: #e8e020;
				--color-cosmos: #1a1aff;
				--color-signal: #ff3c00;
				--font-title: 'Righteous', cursive;
				--font-body: 'Montserrat', sans-serif;
				--font-mono: 'DM Mono', monospace;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			html {
				scroll-snap-type: y mandatory;
				scroll-behavior: smooth;
			}

			body {
				background-color: var(--color-void);
				color: var(--color-lunar);
				font-family: var(--font-body);
				-webkit-font-smoothing: antialiased;
			}

			/* Scanlines fijos */
			body::before {
				content: '';
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 100;
				background-image: repeating-linear-gradient(
					0deg,
					transparent 0px,
					transparent 2px,
					rgba(255, 255, 255, 0.016) 2px,
					rgba(255, 255, 255, 0.016) 4px
				);
			}

			/* ─── Corner brackets ───────────────────────────────────────────────── */
			.corner {
				position: fixed;
				width: 22px;
				height: 22px;
				pointer-events: none;
				z-index: 50;
				opacity: 0.28;
			}
			.corner--tl {
				top: 1.25rem;
				left: 1.25rem;
				border-top: 1px solid var(--color-chrome);
				border-left: 1px solid var(--color-chrome);
			}
			.corner--tr {
				top: 1.25rem;
				right: 1.25rem;
				border-top: 1px solid var(--color-chrome);
				border-right: 1px solid var(--color-chrome);
			}
			.corner--bl {
				bottom: 1.25rem;
				left: 1.25rem;
				border-bottom: 1px solid var(--color-chrome);
				border-left: 1px solid var(--color-chrome);
			}
			.corner--br {
				bottom: 1.25rem;
				right: 1.25rem;
				border-bottom: 1px solid var(--color-chrome);
				border-right: 1px solid var(--color-chrome);
			}

			/* ─── Fixed Header ──────────────────────────────────────────────────── */
			.page-header {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				z-index: 40;
				padding: 1.75rem 2rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}

			.brand-wordmark {
				font-family: var(--font-title);
				font-size: clamp(1rem, 2.5vw, 1.35rem);
				letter-spacing: 0.06em;
				color: var(--color-lunar);
				text-decoration: none;
				mix-blend-mode: difference;
			}

			.nav-info {
				font-family: var(--font-mono);
				font-size: 0.6rem;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: rgba(245, 245, 240, 0.4);
				text-decoration: none;
				border-bottom: 1px solid rgba(245, 245, 240, 0.2);
				padding-bottom: 1px;
				transition:
					color 0.2s,
					border-color 0.2s;
			}
			.nav-info:hover {
				color: var(--color-orbit);
				border-color: var(--color-orbit);
			}

			/* ─── Snap sections ─────────────────────────────────────────────────── */
			.snap-section {
				scroll-snap-align: start;
				height: 100dvh;
				position: relative;
				display: flex;
				flex-direction: column;
				justify-content: center;
				overflow: hidden;
			}

			/* ═══════════════════════════════════════════════════════════════════════
         SECTION 1 — HERO
      ═══════════════════════════════════════════════════════════════════════ */
			.s-hero {
				background-color: var(--color-void);
				padding: 0 clamp(1.5rem, 6vw, 6rem);
				gap: 0;
			}

			.hero-eyebrow {
				font-family: var(--font-mono);
				font-size: 0.6rem;
				letter-spacing: 0.28em;
				text-transform: uppercase;
				color: rgba(245, 245, 240, 0.32);
				margin-bottom: 2rem;
			}

			/* Glitch title */
			.glitch-wrap {
				position: relative;
				overflow: hidden;
			}

			.glitch-title {
				font-family: var(--font-title);
				font-size: clamp(3.2rem, 10.5vw, 9.5rem);
				line-height: 0.92;
				letter-spacing: -0.02em;
				color: var(--color-lunar);
				position: relative;
				display: inline-block;
			}

			.glitch-title::before,
			.glitch-title::after {
				content: attr(data-text);
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				font-family: inherit;
				font-size: inherit;
				line-height: inherit;
				letter-spacing: inherit;
			}

			.glitch-title::before {
				color: var(--color-signal);
				animation: glitch-a 5s 1.5s infinite;
				z-index: -1;
			}
			.glitch-title::after {
				color: var(--color-cosmos);
				animation: glitch-b 5s 1.5s infinite;
				z-index: -2;
			}

			@keyframes glitch-a {
				0%,
				82%,
				100% {
					clip-path: inset(100% 0 0 0);
					transform: translate(0);
				}
				84% {
					clip-path: inset(22% 0 55% 0);
					transform: translate(-5px, 1px);
				}
				86% {
					clip-path: inset(68% 0 12% 0);
					transform: translate(4px, 0);
				}
				88% {
					clip-path: inset(44% 0 40% 0);
					transform: translate(-3px, -1px);
				}
				90% {
					clip-path: inset(8% 0 78% 0);
					transform: translate(5px, 1px);
				}
				92% {
					clip-path: inset(100% 0 0 0);
					transform: translate(0);
				}
			}

			@keyframes glitch-b {
				0%,
				83%,
				100% {
					clip-path: inset(100% 0 0 0);
					transform: translate(0);
				}
				85% {
					clip-path: inset(55% 0 30% 0);
					transform: translate(4px, 0);
				}
				87% {
					clip-path: inset(12% 0 72% 0);
					transform: translate(-4px, 1px);
				}
				89% {
					clip-path: inset(75% 0 8% 0);
					transform: translate(3px, -1px);
				}
				91% {
					clip-path: inset(30% 0 50% 0);
					transform: translate(-2px, 0);
				}
				93% {
					clip-path: inset(100% 0 0 0);
					transform: translate(0);
				}
			}

			.hero-subtitle {
				font-family: var(--font-body);
				font-weight: 300;
				font-size: clamp(0.9rem, 2.2vw, 1.5rem);
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: rgba(245, 245, 240, 0.45);
				margin-top: 1.75rem;
			}

			.hero-bottom {
				position: absolute;
				bottom: 2.5rem;
				left: clamp(1.5rem, 6vw, 6rem);
				right: clamp(1.5rem, 6vw, 6rem);
				display: flex;
				align-items: flex-end;
				justify-content: space-between;
			}

			.hero-bottom-year {
				font-family: var(--font-mono);
				font-size: 0.58rem;
				letter-spacing: 0.18em;
				color: rgba(245, 245, 240, 0.2);
			}

			.scroll-line {
				width: 1px;
				height: 48px;
				background: linear-gradient(
					to bottom,
					rgba(245, 245, 240, 0.3),
					transparent
				);
				animation: scrollPulse 2.2s ease-in-out infinite;
			}

			@keyframes scrollPulse {
				0%,
				100% {
					opacity: 0.35;
					transform: scaleY(1);
				}
				50% {
					opacity: 1;
					transform: scaleY(1.2);
				}
			}

			/* ═══════════════════════════════════════════════════════════════════════
         SECTION 2 — DISEÑO (white)
      ═══════════════════════════════════════════════════════════════════════ */
			.s-diseno {
				background-color: var(--color-lunar);
				color: var(--color-void);
				padding: clamp(5rem, 8vh, 7rem) clamp(1.5rem, 6vw, 6rem)
					clamp(2rem, 4vh, 4rem);
			}

			.section-meta {
				display: flex;
				align-items: baseline;
				gap: 1.5rem;
				margin-bottom: 3rem;
			}

			.section-number {
				font-family: var(--font-title);
				font-size: clamp(4rem, 10vw, 8rem);
				line-height: 1;
				color: rgba(10, 10, 10, 0.06);
				user-select: none;
				flex-shrink: 0;
			}

			.section-label {
				font-family: var(--font-mono);
				font-size: 0.6rem;
				letter-spacing: 0.24em;
				text-transform: uppercase;
				color: rgba(10, 10, 10, 0.38);
			}

			.section-label.light {
				color: rgba(245, 245, 240, 0.38);
			}

			.pull-quote {
				font-family: var(--font-body);
				font-weight: 300;
				font-style: italic;
				font-size: clamp(1.2rem, 2.8vw, 2rem);
				line-height: 1.4;
				color: rgba(10, 10, 10, 0.88);
				max-width: 720px;
				border-left: 2px solid rgba(10, 10, 10, 0.12);
				padding-left: 1.5rem;
				margin-bottom: 2rem;
			}

			.body-text {
				font-family: var(--font-body);
				font-weight: 400;
				font-size: clamp(0.875rem, 1.4vw, 1rem);
				line-height: 1.75;
				color: rgba(10, 10, 10, 0.62);
				max-width: 600px;
				margin-bottom: 2.5rem;
			}

			.spec-line {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem 1rem;
				font-family: var(--font-mono);
				font-size: 0.58rem;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: rgba(10, 10, 10, 0.35);
				border-top: 1px solid rgba(10, 10, 10, 0.1);
				padding-top: 1.25rem;
			}

			/* ═══════════════════════════════════════════════════════════════════════
         SECTION 3 — STATEMENT (black)
      ═══════════════════════════════════════════════════════════════════════ */
			.s-statement {
				background-color: var(--color-void);
				padding: clamp(5rem, 8vh, 7rem) clamp(1.5rem, 6vw, 6rem)
					clamp(2rem, 4vh, 4rem);
				justify-content: flex-end;
			}

			.statement-eyebrow {
				font-family: var(--font-mono);
				font-size: 0.6rem;
				letter-spacing: 0.24em;
				text-transform: uppercase;
				color: var(--color-orbit);
				margin-bottom: 2rem;
			}

			.statement-title {
				font-family: var(--font-title);
				font-size: clamp(2.4rem, 7vw, 6.5rem);
				line-height: 1;
				letter-spacing: -0.02em;
				color: var(--color-lunar);
				margin-bottom: 1.5rem;
				max-width: 900px;
			}

			.statement-sub {
				font-family: var(--font-body);
				font-weight: 300;
				font-size: clamp(1rem, 2vw, 1.35rem);
				letter-spacing: 0.04em;
				color: rgba(245, 245, 240, 0.5);
				max-width: 600px;
				margin-bottom: 2.5rem;
			}

			.statement-rule {
				width: 48px;
				height: 1px;
				background: rgba(245, 245, 240, 0.2);
				margin-bottom: 2rem;
			}

			.statement-body {
				font-family: var(--font-body);
				font-weight: 300;
				font-size: clamp(0.875rem, 1.4vw, 1rem);
				line-height: 1.75;
				color: rgba(245, 245, 240, 0.45);
				max-width: 520px;
			}

			/* ═══════════════════════════════════════════════════════════════════════
         SECTION 4 — FRASES (black)
      ═══════════════════════════════════════════════════════════════════════ */
			.s-frases {
				background-color: var(--color-void);
				padding: clamp(5rem, 8vh, 7rem) clamp(1.5rem, 6vw, 6rem)
					clamp(2rem, 4vh, 4rem);
				justify-content: space-between;
				border-top: 1px solid rgba(245, 245, 240, 0.06);
			}

			.frases-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
			}

			.phrases-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: clamp(1rem, 2.5vh, 2rem) clamp(1rem, 3vw, 3rem);
				flex: 1;
				align-content: center;
				padding: 1.5rem 0;
			}

			.phrase {
				font-family: var(--font-mono);
				font-size: clamp(0.7rem, 1.2vw, 0.875rem);
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--color-lunar);
				opacity: 0;
				animation: phrase-flicker var(--dur, 5s) var(--delay, 0s)
					infinite;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.phrase--accent {
				color: var(--color-orbit);
			}

			@keyframes phrase-flicker {
				0% {
					opacity: 0;
				}
				8% {
					opacity: 1;
				}
				14% {
					opacity: 0.2;
				}
				18% {
					opacity: 1;
				}
				35% {
					opacity: 1;
				}
				42% {
					opacity: 0;
				}
				100% {
					opacity: 0;
				}
			}

			.frases-footer {
				font-family: var(--font-mono);
				font-size: 0.55rem;
				letter-spacing: 0.2em;
				color: rgba(245, 245, 240, 0.18);
				text-transform: uppercase;
			}

			/* ═══════════════════════════════════════════════════════════════════════
         SECTION 5 — IA MANIFESTO (white)
      ═══════════════════════════════════════════════════════════════════════ */
			.s-ia {
				background-color: var(--color-lunar);
				color: var(--color-void);
				padding: clamp(5rem, 8vh, 7rem) clamp(1.5rem, 6vw, 6rem)
					clamp(2rem, 4vh, 4rem);
			}

			.ia-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 4rem;
				align-items: start;
				margin-top: 1rem;
			}

			.ia-left h2 {
				font-family: var(--font-title);
				font-size: clamp(1.6rem, 3.5vw, 2.8rem);
				line-height: 1.1;
				letter-spacing: -0.01em;
				color: var(--color-void);
				margin-bottom: 2rem;
			}

			.ia-right p {
				font-family: var(--font-body);
				font-weight: 400;
				font-size: clamp(0.875rem, 1.3vw, 1rem);
				line-height: 1.8;
				color: rgba(10, 10, 10, 0.6);
				margin-bottom: 1.5rem;
			}

			.ia-right p:last-child {
				margin-bottom: 0;
			}

			.highlight {
				color: var(--color-void);
				font-weight: 600;
			}

			/* ═══════════════════════════════════════════════════════════════════════
         SECTION 6 — NFC CTA (black)
      ═══════════════════════════════════════════════════════════════════════ */
			.s-cta {
				background-color: var(--color-void);
				padding: clamp(5rem, 8vh, 7rem) clamp(1.5rem, 6vw, 6rem);
				align-items: center;
				text-align: center;
				gap: 0;
			}

			/* NFC pulse rings */
			.nfc-rings {
				position: relative;
				width: 80px;
				height: 80px;
				display: flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 3rem;
			}

			.nfc-rings::before,
			.nfc-rings::after {
				content: '';
				position: absolute;
				border-radius: 50%;
				border: 1px solid rgba(232, 224, 32, 0.35);
				animation: ring-expand 2.4s ease-out infinite;
			}

			.nfc-rings::before {
				width: 80px;
				height: 80px;
				animation-delay: 0s;
			}

			.nfc-rings::after {
				width: 80px;
				height: 80px;
				animation-delay: 1.2s;
			}

			.nfc-core {
				width: 10px;
				height: 10px;
				border-radius: 50%;
				background: var(--color-orbit);
				animation: core-pulse 2.4s ease-in-out infinite;
			}

			@keyframes ring-expand {
				0% {
					transform: scale(1);
					opacity: 0.5;
				}
				100% {
					transform: scale(3.5);
					opacity: 0;
				}
			}

			@keyframes core-pulse {
				0%,
				100% {
					opacity: 1;
					transform: scale(1);
				}
				50% {
					opacity: 0.5;
					transform: scale(0.75);
				}
			}

			.cta-command {
				font-family: var(--font-title);
				font-size: clamp(1.6rem, 4.5vw, 4rem);
				letter-spacing: 0.04em;
				color: var(--color-lunar);
				line-height: 1.1;
				margin-bottom: 2.5rem;
			}

			.cta-divider {
				width: 40px;
				height: 1px;
				background: rgba(245, 245, 240, 0.15);
				margin: 0 auto 2.5rem;
			}

			.cta-question {
				font-family: var(--font-body);
				font-weight: 300;
				font-style: italic;
				font-size: clamp(0.9rem, 1.8vw, 1.2rem);
				line-height: 1.65;
				color: rgba(245, 245, 240, 0.45);
				max-width: 560px;
			}

			.cta-question em {
				font-style: normal;
				color: var(--color-orbit);
				font-weight: 400;
			}

			/* ─── Responsive ────────────────────────────────────────────────────── */
			@media (max-width: 768px) {
				.ia-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}

				.phrases-grid {
					grid-template-columns: repeat(2, 1fr);
				}

				.phrase {
					white-space: normal;
				}
			}

			@media (max-width: 480px) {
				.phrases-grid {
					grid-template-columns: 1fr;
				}
			}

			/* ─── Reduced motion ────────────────────────────────────────────────── */
			@media (prefers-reduced-motion: reduce) {
				.glitch-title::before,
				.glitch-title::after,
				.phrase,
				.scroll-line,
				.nfc-rings::before,
				.nfc-rings::after,
				.nfc-core {
					animation: none;
				}

				.phrase {
					opacity: 1;
				}
				.nfc-rings::before,
				.nfc-rings::after {
					transform: scale(1.5);
					opacity: 0.2;
				}
			}
		</style>
	</head>
	<body>
		<!-- Corner brackets -->
		<div class='corner corner--tl'></div>
		<div class='corner corner--tr'></div>
		<div class='corner corner--bl'></div>
		<div class='corner corner--br'></div>

		<!-- Fixed header -->
		<header class='page-header'>
			<a
				href='/'
				class='brand-wordmark'
				>Mar An Cloth</a
			>
			<a
				href='/info'
				class='nav-info'
				>Info de prenda →</a
			>
		</header>

		<!-- ═══ SECTION 1 — HERO ════════════════════════════════════════════════ -->
		<section class='snap-section s-hero'>
			<p class='hero-eyebrow'>Mar An Cloth · Colección 2026</p>

			<div class='glitch-wrap'>
				<h1
					class='glitch-title'
					data-text='NOSTALGIA PROGRAMADA'
				>
					NOSTALGIA<br />PROGRAMADA
				</h1>
			</div>

			<p class='hero-subtitle'>El error en la realidad</p>

			<div class='hero-bottom'>
				<span class='hero-bottom-year'>2026 · Mexico City</span>
				<div class='scroll-line'></div>
			</div>
		</section>

		<!-- ═══ SECTION 2 — DISEÑO ══════════════════════════════════════════════ -->
		<section class='snap-section s-diseno'>
			<div class='section-meta'>
				<span
					class='section-number'
					aria-hidden='true'
					>01</span
				>
				<span class='section-label'>Sobre la Pieza</span>
			</div>

			<blockquote class='pull-quote'>
				"Una silueta fluida pero estructurada, coronada por un cuello
				alto con un lazo que evoca la sofisticación de esa época."
			</blockquote>

