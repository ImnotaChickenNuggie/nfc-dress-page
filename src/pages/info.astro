---
import LanyardInfo from '../components/Lanyard/LanyardInfo';
import { EtiquetaSection } from '../components/sections/EtiquetaSection';
---

<html lang='es'>
	<head>
		<meta charset='utf-8' />
		<link
			rel='icon'
			type='image/svg+xml'
			href='/favicon.svg'
		/>
		<meta
			name='viewport'
			content='width=device-width, initial-scale=1'
		/>
		<meta
			name='theme-color'
			content='#0a0a0a'
		/>
		<title>Mar An Cloth — Información de Prenda</title>

		<link
			rel='preconnect'
			href='https://fonts.googleapis.com'
		/>
		<link
			rel='preconnect'
			href='https://fonts.gstatic.com'
			crossorigin
		/>
		<link
			href='https://fonts.googleapis.com/css2?family=Righteous&family=Montserrat:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap'
			rel='stylesheet'
		/>

		<style>
			:root {
				--color-void: #0a0a0a;
				--color-lunar: #f5f5f0;
				--color-chrome: #c8c8c8;
				--color-orbit: #e8e020;
				--color-cosmos: #1a1aff;
				--color-signal: #ff3c00;
				--font-title: 'Righteous', cursive;
				--font-body: 'Montserrat', sans-serif;
				--font-mono: 'DM Mono', monospace;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			html {
				scroll-behavior: smooth;
				scroll-snap-type: y mandatory;
			}

			body {
				background-color: var(--color-void);
				color: var(--color-lunar);
				font-family: var(--font-body);
				-webkit-font-smoothing: antialiased;
			}

			/* ─── Scanlines ─── */
			body::before {
				content: '';
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 1;
				background-image: repeating-linear-gradient(
					0deg,
					transparent,
					transparent 2px,
					rgba(255, 255, 255, 0.016) 2px,
					rgba(255, 255, 255, 0.016) 4px
				);
			}

			/* Decorative orbit circles */
			body::after {
				content: '';
				position: fixed;
				top: -25vw;
				right: -18vw;
				width: 65vw;
				height: 65vw;
				border-radius: 50%;
				border: 1px solid rgba(232, 224, 32, 0.06);
				pointer-events: none;
				z-index: 0;
			}

			/* ─── Corner brackets ─── */
			.corner {
				position: fixed;
				width: 22px;
				height: 22px;
				pointer-events: none;
				z-index: 2;
				opacity: 0.28;
			}
			.corner--tl {
				top: 1.25rem;
				left: 1.25rem;
				border-top: 1px solid var(--color-chrome);
				border-left: 1px solid var(--color-chrome);
			}
			.corner--tr {
				top: 1.25rem;
				right: 1.25rem;
				border-top: 1px solid var(--color-chrome);
				border-right: 1px solid var(--color-chrome);
			}
			.corner--bl {
				bottom: 1.25rem;
				left: 1.25rem;
				border-bottom: 1px solid var(--color-chrome);
				border-left: 1px solid var(--color-chrome);
			}
			.corner--br {
				bottom: 1.25rem;
				right: 1.25rem;
				border-bottom: 1px solid var(--color-chrome);
				border-right: 1px solid var(--color-chrome);
			}

			/* ─── Header ─── */
			.page-header {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				z-index: 10;
				padding: 1.75rem 2rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}

			.brand-wordmark {
				font-family: var(--font-title);
				font-size: clamp(1rem, 2.5vw, 1.35rem);
				letter-spacing: 0.06em;
				color: var(--color-lunar);
				text-decoration: none;
			}

			.nfc-badge {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-family: var(--font-body);
				font-size: 0.58rem;
				font-weight: 600;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--color-orbit);
				border: 1px solid rgba(232, 224, 32, 0.35);
				padding: 0.32rem 0.7rem;
			}

			.nfc-dot {
				width: 5px;
				height: 5px;
				border-radius: 50%;
				background: var(--color-orbit);
				animation: pulse 2s ease-in-out infinite;
			}

			@keyframes pulse {
				0%,
				100% {
					opacity: 1;
					transform: scale(1);
				}
				50% {
					opacity: 0.35;
					transform: scale(0.65);
				}
			}

			/* ─── Sections ─── */
			.snap-section {
				scroll-snap-align: start;
				height: 100dvh;
				position: relative;
				z-index: 1;
			}

			/* Section 1 — Lanyard: sin flex, el canvas llena todo */
			.section-lanyard {
				background-color: var(--color-void);
				overflow: hidden;
			}

			/* astro-island no tiene altura por defecto — forzar que llene la sección */
			.section-lanyard astro-island {
				display: block;
				width: 100%;
				height: 100%;
			}

			/* Section 2 — Etiqueta */
			.section-etiqueta {
				background-color: var(--color-lunar);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 1.5rem;
			}

			/* ─── Footer ─── */
			.page-footer {
				background-color: var(--color-void);
				padding: 2rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}

			.footer-copy {
				font-family: var(--font-body);
				font-size: 0.58rem;
				font-weight: 300;
				letter-spacing: 0.16em;
				color: rgba(245, 245, 240, 0.2);
				text-transform: uppercase;
			}

			.footer-line {
				flex: 1;
				height: 1px;
				background: rgba(200, 200, 200, 0.1);
				margin: 0 1.5rem;
			}
		</style>
	</head>
	<body class='overflow-y-hidden'>
		<!-- Corner brackets -->
		<div class='corner corner--tl'></div>
		<div class='corner corner--tr'></div>
		<div class='corner corner--bl'></div>
		<div class='corner corner--br'></div>

		<!-- Fixed header -->
		<header class='page-header'>
			<a
				href='/'
				class='brand-wordmark'
				>Mar An Cloth</a
			>
			<div class='nfc-badge'>
				<span class='nfc-dot'></span>
				NFC Verified
			</div>
		</header>

		<!-- Section 1: Lanyard 3D interactivo -->
		<section class='snap-section section-lanyard'>
			<LanyardInfo
				client:load
				position={[0, 0, 16]}
				gravity={[0, -40, 0]}
			/>
		</section>
	</body>
</html>
